{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ADE Workbench",
  "version": "0.1.0",
  "identifier": "ai.ade.workbench",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ADE · Agentic Document Environment",
        "width": 1520,
        "height": 960,
        "minWidth": 1040,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "shortDescription": "多 Agent 文档与研发工作台",
    "longDescription": "在真实项目中阅读、批注、派发 Agent 任务并审核修改。"
  }
}

